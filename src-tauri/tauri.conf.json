{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dexter",
  "version": "0.1.0",
  "identifier": "com.codacus.voice-assistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Dexter",
        "width": 380,
        "height": 420,
        "resizable": true,
        "decorations": true,
        "minimizable": false,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "category": "Utility",
    "shortDescription": "Voice-first Desktop-Assistent",
    "longDescription": "Dexter ist ein sprachgesteuerter Desktop-Assistent: Push-to-Talk-Diktat, lokales LLM (llama.cpp), Piper-TTS, Tools und Sprach-Routing an CLI-Coding-Agenten.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    }
  }
}